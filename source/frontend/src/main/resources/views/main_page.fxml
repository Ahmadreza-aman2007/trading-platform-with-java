<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="app.controllers.mainPage.MainController" fx:id="root"
           nodeOrientation="RIGHT_TO_LEFT">
   <VBox fx:id="mainPage">
      <HBox styleClass="header" alignment="CENTER_RIGHT">
         <Label text="سمساری احمد و پارسا" styleClass="brand-title" />
         <Region HBox.hgrow="ALWAYS"/>
         <HBox>
            <TextField promptText="جستوجو...." fx:id="searchField" styleClass="field searchField" onAction="#handleQuickSearch" />
            <Button styleClass="primary-button" onAction="#handleQuickSearch">
               <graphic>
                  <ImageView fitHeight="40" fitWidth="40" preserveRatio="true">
                     <Image url="@/icons/search.png"/>
                  </ImageView>
               </graphic>
            </Button>
         </HBox>
         <Region HBox.hgrow="ALWAYS"/>
         <HBox spacing="40">
            <Button text="🔎 جستجوی پیشرفته" styleClass="primary-button" onAction="#openSearchBar"/>
            <Button onAction="#goToLoginPage" text="👤 ورود/ثبت نام"
                    styleClass="primary-button"  fx:id="loginButton"/>
            <Button text="⚙ پنل کاربری" visible="false" fx:id="userPanel" styleClass="primary-button" onAction="#goToPanelPage"/>
         </HBox>
      </HBox>
      <ScrollPane fitToHeight="true" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: transparent; -fx-background-color: transparent; -fx-padding: 0;">
         <TilePane fx:id="adsContainer"
                   prefColumns="3"
                   hgap="20"
                   vgap="20"
                   style="-fx-padding: 20; -fx-background-color: transparent;"/>
      </ScrollPane>
      <Label fx:id="emptyLabel" text="❌ هیچ آگهی تأییدشده‌ای وجود ندارد."
             style="-fx-font-size: 1.2em; -fx-text-fill: #7f8c8d; -fx-padding: 40;"
             visible="false" managed="false"/>
   </VBox>
   <VBox fx:id="searchPanel" styleClass="advanced-search-bar" alignment="CENTER" maxWidth="-Infinity" maxHeight="-Infinity" spacing="40">
      <Label text="جستجوی پیشرفته "/>
      <HBox>
         <TextField promptText="کلمه کلیدی" fx:id="keywordField"/>
      </HBox>
      <HBox>
         <ComboBox promptText="دسته بندی" fx:id="categoryCombo"/>
         <Region HBox.hgrow="ALWAYS"/>
         <ComboBox promptText="شهر" fx:id="cityCombo"/>
      </HBox>
         <VBox>
            <Label text="قیمت"/>
            <HBox>
               <Label text="از"/>
               <Slider min="0" max="100000000000" value="0" showTickMarks="true" showTickLabels="true" fx:id="minPriceSlider"/>
               <Label text="0" fx:id="minPriceLabel"/>
               <TextField fx:id="minPriceField" prefWidth="120" text="۰"
                          style="-fx-alignment: CENTER; -fx-padding: 4 8;"/>
            </HBox>
            <HBox>
            <Label text="تا" />
            <Slider min="0" max="100000000000" value="100000000000" showTickLabels="true" showTickMarks="true" fx:id="maxPriceSlider"/>
            <Label text="1,000,000,000" fx:id="maxPriceLabel"/>
               <TextField fx:id="maxPriceField" prefWidth="120" text="۱۰۰,۰۰۰,۰۰۰,۰۰۰"
                          style="-fx-alignment: CENTER; -fx-padding: 4 8;"/>
            </HBox>
            <HBox>
               <Button text="بستن" styleClass="primary-button" onAction="#closeSearchBar"/>
               <Region HBox.hgrow="ALWAYS"/>
               <Button text="جستجو" styleClass="primary-button" onAction="#handleAdvancedSearch"/>
            </HBox>
            <Label fx:id="priceErrorLabel" style="-fx-text-fill: red; -fx-font-size: 12px;"
                   visible="false" managed="false"/>
         </VBox>
   </VBox>


</StackPane>