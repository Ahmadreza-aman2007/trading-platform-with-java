<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Hyperlink?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.controllers.panel.PanelController" fx:id="root"
            nodeOrientation="RIGHT_TO_LEFT">
    <top>
        <HBox alignment="CENTER_RIGHT" styleClass="header">
            <Label text="به پنل کاربری خوش آمدید" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="80">
                <Button text="بازگشت" styleClass="primary-button" onAction="#goToMainPage" />
                <Button text="خروج ازحساب کاربری" styleClass="exit-button" onAction="#exitOfAccount" />
            </HBox>
        </HBox>

    </top>

    <left>
        <StackPane styleClass="list">

            <VBox styleClass="selection-box" fx:id="commonUserPanelList">
                <HBox styleClass="list-option">
                    <Hyperlink text="اطلاعات کاربری" onAction="#goToDashboard"/>
                </HBox>
                <HBox styleClass="list-option">
                    <Hyperlink text="....." />
                </HBox>
                <HBox styleClass="list-option">
                    <Hyperlink text="....." />
                </HBox>
                <HBox styleClass="list-option">
                    <Hyperlink text="....." />
                </HBox>
                <HBox styleClass="list-option">
                    <Hyperlink text="....." />
                </HBox>
                <HBox styleClass="list-option">
                    <Region VBox.vgrow="ALWAYS" />
                </HBox>
            </VBox>
            <VBox styleClass="selection-box" fx:id="managerPanelList" visible="false">
                <HBox styleClass="list-option">
                    <Hyperlink text="اطلاعات کاربری" onAction="#goToDashboard" />
                </HBox>
                <HBox styleClass="list-option">
                    <Hyperlink text="لیست کاربران"  onAction="#goToUsersList"/>
                </HBox>
                <HBox styleClass="list-option">
                    <Hyperlink text="....." />
                </HBox>
                <HBox styleClass="list-option">
                    <Hyperlink text="....." />
                </HBox>
                <HBox styleClass="list-option">
                    <Hyperlink text="....." />
                </HBox>
                <HBox styleClass="list-option">
                    <Region VBox.vgrow="ALWAYS" />
                </HBox>
            </VBox>
        </StackPane>
    </left>
    <center>
        <StackPane styleClass="contentContainer" fx:id="contentContainer">

        </StackPane>
    </center>


</BorderPane>