<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="app.controllers.panel.commonUser.MyAdsController"
      spacing="20"
      style="-fx-padding: 20; -fx-background-color: #f4f6f9;"
      nodeOrientation="RIGHT_TO_LEFT">

    <!-- ===== هدر ===== -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="📦 آگهی‌های من" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="➕ ثبت آگهی جدید" styleClass="primary-button" onAction="#openAddAdDialog"/>
    </HBox>

    <Separator style="-fx-background-color: #ddd; -fx-pref-height: 1;"/>

    <!-- ===== محتوای اصلی (کارت‌ها) ===== -->
    <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-padding: 0;">
        <TilePane fx:id="adsContainer"  hgap="20" vgap="20"
                  style="-fx-padding: 10; -fx-background-color: transparent;"/>
    </ScrollPane>

    <Label fx:id="emptyLabel" text="❌ هنوز آگهی ثبت نکرده‌اید."
           style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d; -fx-padding: 40;"
           visible="false" managed="false"/>

    <StackPane fx:id="messageOverlay"
               visible="false"
               managed="false"
               style="-fx-background-color: rgba(0,0,0,0.3); -fx-padding: 20;">

        <VBox fx:id="messageBox"
              alignment="CENTER"
              spacing="15"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5);"
              maxWidth="400">

            <Label fx:id="messageIcon" text="✅" style="-fx-font-size: 30px;"/>
            <Label fx:id="messageTitle" text="عنوان" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label fx:id="messageContent" text="متن پیام" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d; -fx-wrap-text: true; -fx-text-alignment: CENTER;"/>
            <Button text="✅ متوجه شدم" onAction="#closeMessagePanel"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 30;"/>
        </VBox>
    </StackPane>

</VBox>