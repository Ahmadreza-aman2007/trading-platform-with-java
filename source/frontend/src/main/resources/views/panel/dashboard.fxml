<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="app.controllers.panel.DashboardController"
      nodeOrientation="RIGHT_TO_LEFT" spacing="40">
    <Label text="داشبورد"/>
    <HBox alignment="CENTER" spacing="40">
        <VBox styleClass="dashboard-info" alignment="CENTER" HBox.hgrow="ALWAYS">
            <Label text="نام نمایشی" fx:id="fullname"/>
            <Label text="شماره تلفن" fx:id="phoneNumber"/>
            <Label text="یوزر نیم" fx:id="username"/>
        </VBox>
    </HBox>
</VBox>