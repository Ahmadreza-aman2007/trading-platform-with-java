<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="app.controllers.panel.manager.PendingAdsController"
      spacing="20"
      nodeOrientation="RIGHT_TO_LEFT"
      style="-fx-padding: 20;">

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="📋 آگهی‌های در انتظار بررسی" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🔄 به‌روزرسانی" styleClass="secondary-button" onAction="#refreshList"/>
    </HBox>

    <TableView fx:id="pendingAdsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
            <TableColumn fx:id="titleColumn" text="عنوان" prefWidth="200"/>
            <TableColumn fx:id="priceColumn" text="قیمت" prefWidth="120"/>
            <TableColumn fx:id="sellerColumn" text="فروشنده" prefWidth="120"/>
            <TableColumn fx:id="cityColumn" text="شهر" prefWidth="100"/>
            <TableColumn fx:id="categoryColumn" text="دسته‌بندی" prefWidth="120"/>
            <TableColumn fx:id="createdAtColumn" text="تاریخ ثبت" prefWidth="150"/>
            <TableColumn fx:id="actionColumn" text="عملیات" prefWidth="250"/>
        </columns>
    </TableView>

    <Label fx:id="infoLabel" style="-fx-text-fill: #666; -fx-font-size: 13px;" visible="false"/>

</VBox>