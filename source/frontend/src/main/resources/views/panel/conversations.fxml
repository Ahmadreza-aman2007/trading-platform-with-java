<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="app.controllers.panel.commonUser.ConversationsController"
      spacing="15" style="-fx-padding: 10;">
    <HBox alignment="CENTER_RIGHT" spacing="15">
        <Label text="💬 گفتگوهای من" style="-fx-font-size: 1.4em; -fx-text-fill: #2c3e50;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🔄 به‌روزرسانی" styleClass="primary-button" onAction="#refreshList"/>
    </HBox>
    <Label fx:id="infoLabel" visible="false" style="-fx-text-fill: #7f8c8d;"/>
    <ListView fx:id="conversationsList" prefHeight="500"/>
</VBox>
